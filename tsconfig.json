{
    "compilerOptions": {
        "target": "ES2022",
        "module":"nodenext",
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "moduleResolution": "nodenext",
        "outDir": "dist",
        "rootDir": "./src",
        "strict": false,
        "experimentalDecorators": true,
        "types": ["node"]
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
		"node_modules",
		"tests"
    ]
}